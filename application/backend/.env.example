# TutorConnect Backend Environment Configuration
# Copy this file to .env and update with your actual credentials

# Database Connection
# Format: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/csc648_tutoring_platform_dev

# Authentication
# SECRET_KEY signs authentication tokens. REQUIRED in production (the app will
# refuse to start without it when API_ENV=production). In development it is
# auto-generated per run if unset (which logs everyone out on restart).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Optional: access token lifetime in seconds (default 604800 = 7 days)
# ACCESS_TOKEN_EXPIRE_SECONDS=604800

# API Configuration
API_ENV=development
# API_DEBUG defaults to False. Set to True locally to see SQL echo / error detail.
# It is force-disabled when API_ENV=production regardless of this value.
API_DEBUG=True

# CORS Origins
# The allowed origins are configured in app/config.py.
# Set PROD_DOMAIN to add your production domain (https) to the allowlist.
# PROD_DOMAIN=sfsututor.site
